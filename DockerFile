FROM python:3.10-slim

# Install system dependencies for OpenCV
RUN apt-get update && apt-get install -y \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy requirements from the backend folder and install
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy everything from the backend folder into the /app directory
COPY backend/ .

# Ensure the static directory exists for images
RUN mkdir -p static

EXPOSE 7860

# Run the app (now that files are copied directly into /app, it's just app:app)
CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "7860"]